# Cache Control Headers for OnSeguros Website

# NO CACHE for config.json - always fetch fresh
<FilesMatch "config\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Moderate caching for JS/CSS files (1 hour) - short cache to allow quick updates
<FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
</FilesMatch>

# NO CACHE for HTML files - always check for updates
<FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

# Browser caching for images (30 days)
<FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# Rewrite rules for friendly URLs (if needed)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>
