# Cache Control Headers for OnSeguros Website

# NO CACHE for config.json - always fetch fresh
<FilesMatch "config\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Aggressive caching for static assets (JS/CSS) with versioning
<FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Moderate caching for HTML files (1 hour)
<FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# Browser caching for images (1 year)
<FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp)$">
    Header set Cache-Control "public, max-age=31536000"
</FilesMatch>

# Rewrite rules for friendly URLs (if needed)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>
